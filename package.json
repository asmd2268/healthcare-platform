{
  "name": "healthcare-platform",
  "private": true,
  "packageManager": "npm@11.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@healthcare/web",
    "build": "npm run build --workspace=@healthcare/web",
    "lint": "npm run lint --workspace=@healthcare/web",
    "typecheck": "npm run typecheck --workspace=@healthcare/web",
    "test": "npm run test --workspace=@healthcare/web",
    "test:unit": "npm run test:unit --workspace=@healthcare/web",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "supabase:target:check": "node scripts/supabase-target-safety.mjs check",
    "supabase:target:reset-check": "node scripts/supabase-target-safety.mjs reset",
    "supabase:target:bootstrap-check": "node scripts/supabase-target-safety.mjs bootstrap",
    "supabase:target:seed-check": "node scripts/supabase-target-safety.mjs seed",
    "supabase:target:sql-tests-check": "node scripts/supabase-target-safety.mjs sql-tests",
    "test:sql:staging": "bash scripts/run-staging-sql-tests.sh",
    "test:sql:local": "bash scripts/run-local-sql-tests.sh"
  },
  "devDependencies": {
    "supabase": "^2.109.1"
  }
}
