# Public browser configuration. Use only non-sensitive values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Normal authenticated server configuration. Not needed for local builds that do
# not invoke Supabase-backed features.
DATABASE_URL=
APP_BASE_URL=

# Admin/trusted-job-only configuration. Never expose these values to the browser.
# They are not needed for normal rendering or normal user requests.
SUPABASE_SERVICE_ROLE_KEY=
PLATFORM_OWNER_BOOTSTRAP_CONFIRMATION=

# Reservation-expiry scheduler configuration. Server-only: CRON_SECRET is the
# Vercel Cron authorization secret; the automation principal must be a
# dedicated, registered, non-interactive Auth user UUID.
CRON_SECRET=
INVENTORY_RESERVATION_EXPIRY_AUTOMATION_PRINCIPAL_ID=
# Optional integer from 1 to 1000; defaults to 100 when omitted.
INVENTORY_RESERVATION_EXPIRY_BATCH_LIMIT=
# Optional positive integer. The batch limit multiplied by this value may not
# exceed 1000; defaults to 10 and bounds one scheduler invocation's drain work.
INVENTORY_RESERVATION_EXPIRY_MAX_BATCHES=
