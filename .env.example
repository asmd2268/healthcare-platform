# Public browser configuration. Use only non-sensitive values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-user configuration. Not needed for local placeholder builds.
DATABASE_URL=

# Admin-only configuration. Never expose this key to the browser. It is not
# needed for normal rendering or normal user requests.
SUPABASE_SERVICE_ROLE_KEY=
